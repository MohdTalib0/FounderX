VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Paddle Billing (client — safe to expose token + price ids)
# https://developer.paddle.com/paddlejs/overview
VITE_PADDLE_CLIENT_TOKEN=
VITE_PADDLE_ENVIRONMENT=sandbox
VITE_PADDLE_PRICE_ID_STARTER=
VITE_PADDLE_PRICE_ID_PRO=

# AI keys go in Supabase Edge Function secrets (never in the frontend):
# supabase secrets set OPENROUTER_API_KEY=your_openrouter_api_key
# supabase secrets set OPENROUTER_MODEL_NAME=anthropic/claude-3.5-sonnet

# Paddle server-side (Edge Functions — never in frontend):
# supabase secrets set PADDLE_WEBHOOK_SECRET=your_notification_destination_secret
# supabase secrets set PADDLE_API_KEY=your_paddle_api_key
# supabase secrets set PADDLE_API_BASE=https://sandbox-api.paddle.com   (or https://api.paddle.com for production)
# supabase secrets set PADDLE_PRICE_ID_STARTER=pri_...
# supabase secrets set PADDLE_PRICE_ID_PRO=pri_...
